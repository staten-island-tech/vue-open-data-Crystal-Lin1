{
  "compilerOptions": {
    "target": "ES2022",               
    "module": "ESNext",               
    "moduleResolution": "bundler",       
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }

  },
  "include": [
    "src/**/*",
    "src/**/*.vue",
    "vite.config.ts",
    "vite-env.d.ts"   
  ]
}